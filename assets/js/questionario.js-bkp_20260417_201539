const DATA_FILE = "./saude_coletiva.json";
const THEME_KEY = "questionario_theme_pref_v1";
const FONT_SIZE_KEY = "questionario_font_scale_v1";
const LAST_SESSION_KEY = "questionario_last_session_v1";
const QUESTION_ORDER_KEY_SUFFIX = "question_order_v1";
const TAB_SESSION_KEY_SUFFIX = "tab_session_v1";
const QUESTION_LIMIT = 20;
const FONT_SCALE_MIN = 0.9;
const FONT_SCALE_MAX = 1.3;
const FONT_SCALE_STEP = 0.1;
let storageKey = "questionario_generico_v1";
let renderedQuestionIndex = -1;

const state = {
    questions: [],
    meta: {
        autor: "",
        turma: "",
        disciplina: "",
    },
    index: 0,
    picks: {},
    completed: {},
    errors: 0,
    studentName: "",
    finished: false,
};

const el = {
    quizCard: document.getElementById("quiz-card"),
    progress: document.getElementById("progress"),
    index: document.getElementById("meta-index"),
    step: document.getElementById("meta-step"),
    done: document.getElementById("meta-done"),
    left: document.getElementById("meta-left"),
    errors: document.getElementById("meta-errors"),
    percent: document.getElementById("meta-percent"),
    percentChip: document.getElementById("meta-percent-chip"),
    author: document.getElementById("meta-author"),
    className: document.getElementById("meta-class"),
    disciplineTitle: document.getElementById("meta-discipline"),
    label: document.getElementById("meta-label"),
    theme: document.getElementById("theme-switch"),
    fontDown: document.getElementById("btn-font-down"),
    fontUp: document.getElementById("btn-font-up"),
    fontLabel: document.getElementById("font-size-label"),
    studentName: document.getElementById("student-name"),
    changeName: document.getElementById("btn-change-name"),
    prev: document.getElementById("btn-prev"),
    next: document.getElementById("btn-next"),
    check: document.getElementById("btn-check"),
    footer: document.querySelector("footer"),
};

const stripAnsi = (text) => text.replace(/\u001B\[[0-9;]*[A-Za-z]/g, "");
const themeMedia = window.matchMedia("(prefers-color-scheme: dark)");

function clamp(value, min, max) {
    return Math.min(max, Math.max(min, value));
}

function setText(node, value) {
    if (node) node.textContent = value;
}

function wait(ms) {
    return new Promise((resolve) => window.setTimeout(resolve, ms));
}

async function showShuffleLoader(studentName = state.studentName) {
    const firstName = escapeHtml(getFirstName(studentName) || "Participante");
    await fireAlert({
        title: `Bem-vindo(a) ${firstName}`,
        html: `
      <div class="shuffle-loader">
        <div class="shuffle-loader-orbit" aria-hidden="true">
          <span class="shuffle-loader-core"></span>
          <span class="shuffle-loader-dot dot-1"></span>
          <span class="shuffle-loader-dot dot-2"></span>
          <span class="shuffle-loader-dot dot-3"></span>
        </div>
        <p class="shuffle-loader-text">Aguarde um instante, estamos sorteando as suas perguntas.</p>
      </div>
    `,
        allowOutsideClick: false,
        allowEscapeKey: false,
        showConfirmButton: false,
        didOpen: async () => {
            await wait(5000);
            Swal.close();
        },
    });
}

function escapeHtml(value) {
    return String(value || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
}

function getFirstName(fullName) {
    return String(fullName || "").trim().split(/\s+/)[0] || "";
}

function getLevelIntensity(level) {
    const normalized = slugify(level);
    if (normalized === "facil") return "🔥";
    if (normalized === "medio") return "🔥🔥";
    if (normalized === "dificil") return "🔥🔥🔥";
    return "🔥";
}

function shuffleArray(items) {
    const cloned = [...items];
    for (let index = cloned.length - 1; index > 0; index -= 1) {
        const randomIndex = Math.floor(Math.random() * (index + 1));
        [cloned[index], cloned[randomIndex]] = [cloned[randomIndex], cloned[index]];
    }
    return cloned;
}

function getQuestionOrderKey() {
    return `${storageKey}_${QUESTION_ORDER_KEY_SUFFIX}`;
}

function getTabSessionKey() {
    return `${storageKey}_${TAB_SESSION_KEY_SUFFIX}`;
}

function getQuestionId(question, index) {
    if (question.id) return String(question.id);
    return `q_${index}_${slugify(question.enunciado).slice(0, 64)}`;
}

function setNameModalSkeleton(isOpen) {
    document.body.classList.toggle("name-modal-open", isOpen);
}

function getSwalThemeClass() {
    return document.documentElement.getAttribute("data-theme") === "dark"
        ? "swal-theme-dark"
        : "swal-theme-light";
}

function fireAlert(options) {
    return Swal.fire({
        ...options,
        customClass: {
            popup: `swal-theme ${getSwalThemeClass()}`,
            confirmButton: "swal-confirm-btn",
            cancelButton: "swal-cancel-btn",
            ...(options.customClass || {}),
        },
        buttonsStyling: false,
    });
}

function applyTheme(theme) {
    const safeTheme = theme === "dark" ? "dark" : "light";
    document.documentElement.setAttribute("data-theme", safeTheme);
    el.theme.checked = safeTheme === "dark";
}

function initTheme() {
    const saved = localStorage.getItem(THEME_KEY);
    if (saved === "dark" || saved === "light") {
        applyTheme(saved);
        return;
    }
    applyTheme(themeMedia.matches ? "dark" : "light");
}

function toggleTheme() {
    const next = el.theme.checked ? "dark" : "light";
    applyTheme(next);
    localStorage.setItem(THEME_KEY, next);
}

function updateFontControls(scale) {
    const percent = Math.round(scale * 100);
    document.documentElement.style.setProperty("--quiz-font-scale", String(scale));
    setText(el.fontLabel, `Fonte ${percent}%`);
    if (el.fontDown) el.fontDown.disabled = scale <= FONT_SCALE_MIN;
    if (el.fontUp) el.fontUp.disabled = scale >= FONT_SCALE_MAX;
}

function initFontScale() {
    const saved = Number.parseFloat(localStorage.getItem(FONT_SIZE_KEY) || "");
    const scale = Number.isFinite(saved) ? clamp(saved, FONT_SCALE_MIN, FONT_SCALE_MAX) : 1;
    updateFontControls(scale);
}

function changeFontScale(delta) {
    const current = Number.parseFloat(
        getComputedStyle(document.documentElement).getPropertyValue("--quiz-font-scale")
    ) || 1;
    const next = clamp(Number((current + delta).toFixed(2)), FONT_SCALE_MIN, FONT_SCALE_MAX);
    updateFontControls(next);
    localStorage.setItem(FONT_SIZE_KEY, String(next));
}

function persistSessionSnapshot() {
    saveState();
    const currentTheme = document.documentElement.getAttribute("data-theme");
    if (currentTheme === "dark" || currentTheme === "light") {
        localStorage.setItem(THEME_KEY, currentTheme);
    }
    const currentScale =
        Number.parseFloat(
            getComputedStyle(document.documentElement).getPropertyValue("--quiz-font-scale")
        ) || 1;
    localStorage.setItem(FONT_SIZE_KEY, String(currentScale));
}

function applyPersistentQuestionOrder(questions) {
    const orderKey = getQuestionOrderKey();
    const normalizedQuestions = questions.map((question, index) => ({
        ...question,
        _questionId: getQuestionId(question, index),
    }));

    let storedOrder = [];
    try {
        storedOrder = JSON.parse(localStorage.getItem(orderKey) || "[]");
    } catch (_) {
        storedOrder = [];
    }

    const byId = new Map(normalizedQuestions.map((question) => [question._questionId, question]));
    const orderedQuestions = [];

    if (Array.isArray(storedOrder) && storedOrder.length > 0) {
        storedOrder.forEach((questionId) => {
            if (orderedQuestions.length >= QUESTION_LIMIT) return;
            if (!byId.has(questionId)) return;
            orderedQuestions.push(byId.get(questionId));
            byId.delete(questionId);
        });
    }

    const remainingQuestions = shuffleArray(Array.from(byId.values()));
    const seededQuestions =
        orderedQuestions.length > 0 ? [...orderedQuestions, ...remainingQuestions] : shuffleArray(normalizedQuestions);
    const finalQuestions = seededQuestions.slice(0, Math.min(QUESTION_LIMIT, seededQuestions.length));

    localStorage.setItem(
        orderKey,
        JSON.stringify(finalQuestions.map((question) => question._questionId))
    );

    return finalQuestions.map((question) => ({
        ...question,
        alternativas: shuffleArray(question.alternativas || []),
    }));
}

function slugify(value) {
    return (
        String(value || "questionario")
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "")
            .toLowerCase()
            .replace(/[^a-z0-9]+/g, "_")
            .replace(/^_+|_+$/g, "") || "questionario"
    );
}

function saveState() {
    const data = {
        index: state.index,
        picks: state.picks,
        completed: state.completed,
        errors: state.errors,
        studentName: state.studentName,
        finished: !!state.finished,
        updatedAt: new Date().toISOString(),
    };
    localStorage.setItem(storageKey, JSON.stringify(data));
    localStorage.setItem(
        LAST_SESSION_KEY,
        JSON.stringify({
            storageKey,
            questionOrderKey: getQuestionOrderKey(),
            disciplina: state.meta.disciplina || "",
            turma: state.meta.turma || "",
            studentName: state.studentName || "",
            updatedAt: data.updatedAt,
        })
    );
}

function restoreState() {
    try {
        const raw = localStorage.getItem(storageKey);
        if (!raw) return;
        const data = JSON.parse(raw);
        state.index = Number.isInteger(data.index) ? data.index : 0;
        state.picks = data.picks && typeof data.picks === "object" ? data.picks : {};
        state.completed = data.completed && typeof data.completed === "object" ? data.completed : {};
        state.errors = Number.isFinite(data.errors) ? data.errors : 0;
        state.studentName = typeof data.studentName === "string" ? data.studentName.trim() : "";
        state.finished = !!data.finished;
        return data;
    } catch (_) {
        // Ignore invalid persisted data
    }
    return null;
}

function sanitizeRestoredState() {
    const max = Math.max(0, state.questions.length - 1);
    if (!Number.isInteger(state.index) || state.index < 0) state.index = 0;
    if (state.index > max) state.index = max;

    const validPicks = {};
    for (const [k, v] of Object.entries(state.picks || {})) {
        const idx = Number(k);
        if (!Number.isInteger(idx) || idx < 0 || idx > max) continue;
        if (typeof v !== "string" || !/^[A-D]$/.test(v)) continue;
        validPicks[idx] = v;
    }
    state.picks = validPicks;

    const validCompleted = {};
    for (const [k, v] of Object.entries(state.completed || {})) {
        const idx = Number(k);
        if (!Number.isInteger(idx) || idx < 0 || idx > max) continue;
        validCompleted[idx] = !!v;
    }
    state.completed = validCompleted;
    if (!Number.isFinite(state.errors) || state.errors < 0) state.errors = 0;
    state.finished = !!state.finished && state.questions.length > 0;
}

async function ensureStudentName() {
    if (state.studentName) return;
    while (!state.studentName) {
        setNameModalSkeleton(true);
        try {
            const result = await fireAlert({
                title: "👋 Olá, como se chama?",
                input: "text",
                inputPlaceholder: "Digite seu nome",
                allowOutsideClick: false,
                allowEscapeKey: false,
                confirmButtonText: "Vamos começar",
                inputValidator: (value) => {
                    if (!value || !value.trim()) return "Informe seu nome para continuar.";
                    return null;
                },
            });
            state.studentName = String(result.value || "").trim();
            if (state.studentName) {
                const sender = window.EnviarQuestionario;
                if (sender && typeof sender.sendEvent === "function") {
                    sender.sendEvent(getEventPayload("entrada")).catch(() => { });
                }
                await showShuffleLoader();
            }
        } finally {
            setNameModalSkeleton(false);
        }
    }
    saveState();
}

async function changeStudentName() {
    let result;
    result = await fireAlert({
        title: "Alterar nome",
        input: "text",
        inputValue: state.studentName || "",
        inputPlaceholder: "Digite o novo nome",
        showCancelButton: true,
        confirmButtonText: "Salvar",
        cancelButtonText: "Cancelar",
        inputValidator: (value) => {
            if (!value || !value.trim()) return "Informe um nome válido.";
            return null;
        },
    });
    if (!result.isConfirmed) return;
    const previousName = state.studentName;
    const nextName = String(result.value || "").trim();
    if (!nextName || nextName === state.studentName) return;
    setNameModalSkeleton(true);
    try {
        const sender = window.EnviarQuestionario;
        if (sender && typeof sender.sendEvent === "function") {
            sender.sendEvent(
                getEventPayload("alteracao_nome", {
                    aluno: nextName,
                    nomeAnterior: previousName,
                })
            ).catch(() => { });
        }
        await showShuffleLoader();
    } finally {
        setNameModalSkeleton(false);
    }
    resetQuizSession(nextName);
}

async function loadData() {
    const response = await fetch(DATA_FILE, { cache: "no-store" });
    if (!response.ok) throw new Error(`Não foi possível carregar ${DATA_FILE}.`);
    const raw = await response.text();
    const clean = stripAnsi(raw);
    const parsed = JSON.parse(clean);
    if (!parsed.questoes || !Array.isArray(parsed.questoes)) {
        throw new Error('JSON sem lista "questões"');
    }
    if (parsed.questoes.length === 0) throw new Error("JSON sem questões válidas");
    state.meta = {
        autor: parsed.autor || "-",
        turma: parsed.turma || "-",
        disciplina: parsed.disciplina || "Questionário",
    };
    storageKey = `questionario_${slugify(state.meta.disciplina)}_${slugify(state.meta.turma)}_v1`;
    state.questions = applyPersistentQuestionOrder(parsed.questoes);
}

function syncMeta() {
    setText(el.author, state.meta.autor || "-");
    setText(el.className, state.meta.turma || "-");
    setText(el.disciplineTitle, state.meta.disciplina || "Questionário");
    setText(el.label, "Exercício de Simulação");
    document.title = `Questionário - ${state.meta.disciplina || "Questionário"}`;
}

function hasSavedProgress(restoredData) {
    if (!restoredData || typeof restoredData !== "object") return false;
    const hasPicks = restoredData.picks && Object.keys(restoredData.picks).length > 0;
    const hasCompleted = restoredData.completed && Object.keys(restoredData.completed).length > 0;
    const hasErrors = Number.isFinite(restoredData.errors) && restoredData.errors > 0;
    const hasAdvanced = Number.isInteger(restoredData.index) && restoredData.index > 0;
    return !!(hasPicks || hasCompleted || hasErrors || hasAdvanced);
}

async function maybeShowResumeNotice(restoredData) {
    if (!hasSavedProgress(restoredData)) return;
    if (sessionStorage.getItem(getTabSessionKey())) return;
    const lastSessionRaw = localStorage.getItem(LAST_SESSION_KEY);
    const firstName = getFirstName(state.studentName || restoredData?.studentName);
    let lastSavedText = "Ultimo salvamento recente";

    try {
        const lastSession = JSON.parse(lastSessionRaw || "{}");
        if (lastSession.updatedAt) {
            const date = new Date(lastSession.updatedAt);
            if (!Number.isNaN(date.getTime())) {
                lastSavedText = date.toLocaleString("pt-BR");
            }
        }
    } catch (_) {
        // Keep fallback subtitle
    }

    await fireAlert({
        icon: "info",
        title: "Sessão restaurada",
        html: `
      <div class="text-left space-y-3">
        <p class="text-sm font-semibold">Bem vindo(a) novamente ${escapeHtml(firstName || "por aqui")}</p>
        <div class="grid gap-2 text-sm">
          <div><b>Disciplina:</b> ${escapeHtml(state.meta.disciplina || "-")}</div>
          <div><b>Turma:</b> ${escapeHtml(state.meta.turma || "-")}</div>
          <div><b>Questão retomada:</b> ${state.index + 1}/${state.questions.length}</div>
          <div><b>Respostas registradas:</b> ${Object.keys(state.picks || {}).length}</div>
          <div><b>Questões concluídas:</b> ${Object.keys(state.completed || {}).length}</div>
          <div><b>Erros acumulados:</b> ${state.errors}</div>
          <div><b>Último salvamento:</b> ${escapeHtml(lastSavedText)}</div>
        </div>
      </div>
    `,
        confirmButtonText: "Continuar",
    });
}

function currentQuestion() {
    return state.questions[state.index];
}

function isCompleted() {
    return !!state.completed[state.index];
}

function celebrateHit() {
    if (typeof confetti !== "function") return;
    const count = 180;
    const defaults = {
        origin: { y: 0.65 },
        zIndex: 99999,
    };
    function burst(particleRatio, opts) {
        confetti({ ...defaults, ...opts, particleCount: Math.floor(count * particleRatio) });
    }
    burst(0.25, { spread: 30, startVelocity: 55 });
    burst(0.2, { spread: 70 });
    burst(0.35, { spread: 110, decay: 0.92, scalar: 0.9 });
    burst(0.2, { spread: 135, startVelocity: 30, decay: 0.94, scalar: 1.05 });
}

function isLastQuestion() {
    return state.index === state.questions.length - 1;
}

function getPerformanceSummary() {
    const total = state.questions.length || 1;
    const errors = Math.max(0, state.errors);
    const rawAccuracy = ((total - errors) / total) * 100;
    const accuracy = Math.max(0, Math.round(rawAccuracy));
    const correctAnswers = Math.max(0, total - errors);

    if (accuracy >= 90) {
        return {
            label: "excelente",
            stars: 5,
            accentClass: "excellent",
            title: "mandou muito bem!",
            phrase: "Excelente! Você praticamente gabaritou — mostrou que domina o conteúdo com segurança.",
            accuracy,
            correctAnswers,
        };
    }

    if (accuracy >= 75) {
        return {
            label: "ótimo",
            stars: 4,
            accentClass: "great",
            title: "quase lá!",
            phrase: "Ótimo desempenho! Você está muito perto do nível máximo, só ajustar alguns detalhes.",
            accuracy,
            correctAnswers,
        };
    }

    if (accuracy >= 55) {
        return {
            label: "bom",
            stars: 3,
            accentClass: "good",
            title: "tá no caminho certo",
            phrase: "Bom trabalho! Você foi bem, mas ainda dá pra evoluir e ganhar mais consistência.",
            accuracy,
            correctAnswers,
        };
    }

    return {
        label: "medio",
        stars: 2,
        accentClass: "fair",
        title: "bora melhorar",
        phrase: "Você conseguiu concluir, agora é revisar e tentar de novo — a evolução vem rápido.",
        accuracy,
        correctAnswers,
    };
}

function getResultPayload() {
    const total = state.questions.length;
    const performance = getPerformanceSummary();
    const now = new Date();

    return {
        aluno: state.studentName || "Participante",
        turma: state.meta.turma || "-",
        disciplina: state.meta.disciplina || "Questionário",
        totalQuestoes: total,
        erros: state.errors,
        acertos: performance.correctAnswers,
        aproveitamento: performance.accuracy,
        desempenho: performance.label,
        estrelas: performance.stars,
        questaoAtual: state.finished ? "Questionário finalizado" : `Questão ${state.index + 1}/${total}`,
        dataHora: now.toLocaleString("pt-BR"),
    };
}

function getEventPayload(tipo, overrides = {}) {
    const now = new Date();

    return {
        tipo,
        aluno: overrides.aluno || state.studentName || "Participante",
        nomeAnterior: overrides.nomeAnterior || "",
        turma: state.meta.turma || "-",
        disciplina: state.meta.disciplina || "Questionário",
        dataHora: now.toLocaleString("pt-BR"),
    };
}

function celebrateFinalResult(stars) {
    if (typeof confetti !== "function") return;
    const bursts = Math.max(2, stars);
    for (let index = 0; index < bursts; index += 1) {
        confetti({
            particleCount: 90,
            spread: 70 + index * 6,
            startVelocity: 30 + index * 2,
            scalar: 0.9 + index * 0.04,
            zIndex: 99999,
            origin: {
                x: 0.18 + index * (0.64 / Math.max(1, bursts - 1)),
                y: 0.62 - Math.min(index * 0.03, 0.18),
            },
        });
    }
}

