      <div class="rounded-2xl border border-rose-200 bg-rose-50 p-5">
        <h2 class="font-bold text-rose-800">Erro ao carregar o questionário</h2>
        <p class="mt-2 text-rose-700 text-sm">${err.message}</p>
      </div>
    `;
    }
})();
