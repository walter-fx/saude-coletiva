        const isEarned = index < performance.stars;
        return `
      <span
        class="result-star ${isEarned ? "is-earned" : "is-empty"}"
        style="--star-delay:${index * 0.16}s"
        aria-hidden="true"
      >⭐</span>
    `;
    }).join("");

    return `
    <article class="results-shell ${performance.accentClass} fade-in">
      <div class="results-burst results-burst-left"></div>
      <div class="results-burst results-burst-right"></div>
      <div class="results-head">
        <span class="results-chip"><i class="bi bi-trophy-fill"></i> Resultado final</span>
        <h2 class="title-font results-title">${escapeHtml(firstName)}, ${performance.title}</h2>
        <p class="results-subtitle">${escapeHtml(performance.phrase)}</p>
      </div>

      <div class="results-score">
        <div class="score-ring" style="--score-angle:${scoreAngle}">
          <span class="score-ring-value">${performance.accuracy}%</span>
          <span class="score-ring-label">Aproveitamento</span>
        </div>
        <div class="score-copy">
          <div class="results-stars results-stars-inline" aria-label="${performance.stars} de 5 estrelas">
            ${starsMarkup}
          </div>
          <p class="score-label">Desempenho ${performance.label}</p>
          <p class="score-text">Você concluiu ${total} perguntas com ${state.errors} erro(s).</p>
        </div>
      </div>

      <div class="results-grid">
        <div class="results-stat">
          <span class="results-stat-label">Questões</span>
          <strong>${total}</strong>
        </div>
        <div class="results-stat">
          <span class="results-stat-label">Erros</span>
          <strong>${state.errors}</strong>
        </div>
        <div class="results-stat">
          <span class="results-stat-label">Saldo</span>
          <strong>${performance.correctAnswers}</strong>
        </div>
        <div class="results-stat">
          <span class="results-stat-label">Nivel</span>
          <strong>${performance.label}</strong>
        </div>
      </div>

      <div class="results-cta">
        <button
          type="button"
          class="result-submit-button pulse-next"
          data-action="send-to-author"
        >
          <i class="bi bi-cloud-arrow-up-fill"></i>
          <span>Compartilhar desempenho com a autor</span>
        </button>
        <p class="results-helper">No próximo passo vamos ligar esse envio ao servidor para entregar seu resultado a ${authorName}.</p>
      </div>

      <div class="results-secondary-cta">
        <button
          type="button"
          class="result-restart-button"
          data-action="restart-quiz"
        >
          <i class="bi bi-arrow-repeat"></i>
          <span>Refazer questionário</span>
        </button>
      </div>
    </article>
  `;
}

function resetQuizSession(nextStudentName = state.studentName) {
    state.index = 0;
    state.picks = {};
    state.completed = {};
    state.errors = 0;
    state.finished = false;
    state.studentName = String(nextStudentName || "").trim();
    saveState();
    render();
}

function pick(letter) {
    if (isCompleted()) return;
    state.picks[state.index] = letter;
    saveState();
    render();
}

async function checkAnswer() {
    const q = currentQuestion();
    const selected = state.picks[state.index];
    if (!selected) return;

    if (selected === q.gabarito) {
        state.completed[state.index] = true;
        saveState();
        celebrateHit();
        await fireAlert({
            icon: "success",
            title: "Você acertou",
            html: "Muito bem! <br/>Confira a resposta e avance para a próxima.",
            confirmButtonText: "Fechar",
        });
        render();
        return;
    }

    state.errors += 1;
    saveState();
    const result = await fireAlert({
        icon: "error",
        title: "Você errou",
        text: "Não tem problema. Deseja tentar novamente?",
        confirmButtonText: "Tentar novamente",
    });

    if (result.isConfirmed) state.picks[state.index] = null;
    saveState();
    render();
}

function next() {
    if (state.finished) return;
    if (state.index < state.questions.length - 1) {
        state.index += 1;
        saveState();
        render();
        return;
    }

    if (!isCompleted()) return;
    state.finished = true;
    saveState();
    celebrateFinalResult(getPerformanceSummary().stars);
    render();
}

function prev() {
    if (state.index > 0) {
        state.index -= 1;
        saveState();
        render();
    }
}

function getSelectedAlternative(question, letter) {
    return question.alternativas.find((alt) => alt.letra === letter) || null;
}

function getPendingStatusHtml(question, selected) {
    return "";
}

function getDoneStatusHtml(question) {
    const references = Array.isArray(question.referencias) && question.referencias.length > 0
        ? `
      <div class="mt-4 border-t border-emerald-200 pt-4">
        <p class="text-xs uppercase tracking-wide text-emerald-800 font-bold">Referências</p>
        <ol class="mt-2 space-y-2 text-sm text-emerald-800">
          ${question.referencias.map((item) => `<li>${item}</li>`).join("")}
        </ol>
      </div>
    `
        : "";

    return `
    <div class="status-panel mt-5 rounded-2xl border border-emerald-200 bg-emerald-50 p-4">
      <p class="font-bold text-emerald-800">Resposta correta.</p>
      <p class="mt-1 text-sm text-emerald-800">${question.comentario_resposta_certa || `Gabarito: ${question.gabarito}.`}</p>
      ${references}
    </div>
  `;
}

function buildQuestionMarkup(question) {
    const levelBadge = question.nivel
        ? `<span class="inline-flex shrink-0 items-center gap-2 rounded-full border border-amber-200 bg-amber-50 px-3 py-1 text-xs font-bold uppercase tracking-wide text-amber-700"><span>${getLevelIntensity(question.nivel)}</span><span>${escapeHtml(question.nivel)}</span></span>`
        : "";

    const optionsHtml = question.alternativas
        .map((a) => {
            return `
        <button class="option w-full min-h-16 text-left rounded-2xl p-4" data-letter="${a.letra}" type="button">
          <div class="flex items-start gap-3">
            <span class="alt-badge mt-0.5 inline-flex h-8 w-8 items-center justify-center rounded-full text-xs font-bold">${a.letra}</span>
            <div class="flex-1">
              <div class="flex items-start justify-between gap-3">
                <p class="font-semibold text-slate-800">${a.texto}</p>
                <span class="option-state rounded-full bg-slate-900 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wide text-white" data-state-for="${a.letra}"></span>
              </div>
              <p class="option-comment mt-2 text-sm" data-comment-for="${a.letra}"></p>
            </div>
          </div>
        </button>
      `;
        })
        .join("");

    return `
    <article class="quiz-shell fade-in">
      <div class="mb-3 flex items-start justify-between gap-3">
        <h2 class="title-font text-xl font-bold leading-tight md:text-2xl">${question.enunciado}</h2>
        ${levelBadge}
      </div>
      <div class="mt-5 grid gap-3">${optionsHtml}</div>
      <div id="question-status"></div>
    </article>
  `;
}

function syncQuestionCard() {
    const q = currentQuestion();
    const selected = state.picks[state.index];
    const done = isCompleted();
    const statusEl = document.getElementById("question-status");
    const buttons = el.quizCard.querySelectorAll("[data-letter]");

    buttons.forEach((button) => {
        const letter = button.dataset.letter;
        const alt = getSelectedAlternative(q, letter);
        const commentEl = button.querySelector(`[data-comment-for="${letter}"]`);
        const stateEl = button.querySelector(`[data-state-for="${letter}"]`);
        const isSel = selected === letter;
        const isRight = done && letter === q.gabarito;
        const isWrongSel = done && isSel && letter !== q.gabarito;

        button.classList.toggle("selected", isSel && !done);
        button.classList.toggle("correct", isRight);
        button.classList.toggle("wrong", isWrongSel);

        if (commentEl) {
            commentEl.textContent = done ? alt?.comentario || "" : "";
            commentEl.className = `option-comment mt-2 text-sm ${done ? "visible" : ""} ${alt?.correta ? "text-emerald-700" : "text-slate-600"}`;
        }

        if (stateEl) {
            if (done && isRight) {
                stateEl.textContent = "Correta";
                stateEl.className = "option-state rounded-full bg-emerald-600 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wide text-white";
            } else if (done && isWrongSel) {
                stateEl.textContent = "Sua escolha";
                stateEl.className = "option-state rounded-full bg-rose-600 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wide text-white";
            } else if (isSel) {
                stateEl.textContent = "Selecionada";
                stateEl.className = "option-state rounded-full bg-teal-600 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wide text-white";
            } else {
                stateEl.textContent = "";
                stateEl.className = "option-state rounded-full bg-slate-900 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wide text-white";
            }
        }
    });

    if (statusEl) {
        statusEl.innerHTML = done ? getDoneStatusHtml(q) : getPendingStatusHtml(q, selected);
    }
}

function render() {
    const doneCount = Object.keys(state.completed).length;
    const total = state.questions.length;
    const leftCount = Math.max(0, total - doneCount);
    const navPercent = state.finished ? 100 : Math.round((doneCount / Math.max(1, total)) * 100);

    if (state.finished) {
        setText(el.index, "Resultado final");
        setText(el.step, `${total}/${total}`);
        setText(el.done, String(doneCount));
        setText(el.left, "0");
        setText(el.errors, String(state.errors));
        setText(el.percent, "100%");
        setText(el.percentChip, "100%");
        setText(el.studentName, state.studentName || "-");
        if (el.progress) el.progress.style.width = "100%";
        if (el.footer) el.footer.classList.add("hidden");
        if (!el.quizCard.querySelector(".results-shell")) {
            el.quizCard.innerHTML = buildFinalMarkup();
        }
        return;
    }

    if (el.footer) el.footer.classList.remove("hidden");
    const q = currentQuestion();

    setText(el.index, `Questão ${state.index + 1}/${total}`);
    setText(el.step, `${state.index + 1}/${total}`);
    setText(el.done, String(doneCount));
    setText(el.left, String(leftCount));
    setText(el.errors, String(state.errors));
    setText(el.percent, `${navPercent}%`);
    setText(el.percentChip, `${navPercent}%`);
    setText(el.studentName, state.studentName || "-");
    if (el.progress) el.progress.style.width = `${navPercent}%`;

    if (el.prev) el.prev.disabled = state.index === 0;
    if (el.check) el.check.disabled = !state.picks[state.index] || isCompleted();
    if (el.next) {
        el.next.disabled = !isCompleted();
        el.next.innerHTML = isLastQuestion()
            ? 'Finalizar<i class="bi bi-flag-fill ms-1"></i>'
            : 'Próxima<i class="bi bi-arrow-right ms-1"></i>';
    }
    if (el.check) el.check.classList.toggle("pulse-next", !!state.picks[state.index] && !isCompleted());
    if (el.next) {
        el.next.classList.toggle("pulse-next", !el.next.disabled);
        el.next.classList.toggle("finish-mode", isLastQuestion());
    }

    if (renderedQuestionIndex !== state.index || !el.quizCard.querySelector(".quiz-shell")) {
        el.quizCard.innerHTML = buildQuestionMarkup(q);
        renderedQuestionIndex = state.index;
    }

    syncQuestionCard();
}

if (el.check) el.check.addEventListener("click", checkAnswer);
if (el.next) el.next.addEventListener("click", next);
if (el.prev) el.prev.addEventListener("click", prev);
if (el.theme) el.theme.addEventListener("change", toggleTheme);
if (el.fontDown) el.fontDown.addEventListener("click", () => changeFontScale(-FONT_SCALE_STEP));
if (el.fontUp) el.fontUp.addEventListener("click", () => changeFontScale(FONT_SCALE_STEP));
if (el.changeName) el.changeName.addEventListener("click", changeStudentName);
if (el.quizCard) {
    el.quizCard.addEventListener("click", (event) => {
        const actionButton = event.target.closest("[data-action]");
        if (actionButton?.dataset.action === "send-to-author") {
            const sender = window.EnviarQuestionario;
            if (!sender || typeof sender.sendResult !== "function") {
                fireAlert({
                    icon: "error",
                    title: "Envio indisponível",
                    text: "O módulo de envio não foi carregado.",
                    confirmButtonText: "Fechar",
                });
                return;
            }

            const payload = getResultPayload();
            fireAlert({
                title: "Enviando ao autor...",
                html: `
          <div class="shuffle-loader">
            <div class="shuffle-loader-orbit" aria-hidden="true">
              <span class="shuffle-loader-core"></span>
              <span class="shuffle-loader-dot dot-1"></span>
              <span class="shuffle-loader-dot dot-2"></span>
              <span class="shuffle-loader-dot dot-3"></span>
            </div>
            <p class="shuffle-loader-text">Compartilhando o seu desempenho com o autor do questionário.</p>
          </div>
        `,
                allowOutsideClick: false,
                allowEscapeKey: false,
                showConfirmButton: false,
                didOpen: async () => {
                    const result = await sender.sendResult(payload);
                    Swal.close();

                    if (!result.ok) {
                        fireAlert({
                            icon: "error",
                            title: "Não foi possível enviar",
                            text: result.message || "Falha ao compartilhar o resultado com o autor.",
                            confirmButtonText: "Fechar",
                        });
                        return;
                    }

                    fireAlert({
                        icon: "success",
                        title: "Resultado enviado",
                        text: "O seu desempenho foi compartilhado com sucesso.",
                        confirmButtonText: "Finalizar",
                    });
                },
            });
            return;
        }

        if (actionButton?.dataset.action === "restart-quiz") {
            fireAlert({
                icon: "question",
                title: "Refazer questionário?",
                text: "Seu progresso atual sera reiniciado e voce voltara para a primeira pergunta.",
                showCancelButton: true,
                confirmButtonText: "Refazer agora",
                cancelButtonText: "Cancelar",
            }).then((result) => {
                if (!result.isConfirmed) return;
                resetQuizSession();
            });
            return;
        }

        const button = event.target.closest("[data-letter]");
        if (!button) return;
        pick(button.dataset.letter);
    });
}

themeMedia.addEventListener("change", (event) => {
    const saved = localStorage.getItem(THEME_KEY);
    if (saved === "dark" || saved === "light") return;
    applyTheme(event.matches ? "dark" : "light");
});

document.addEventListener("visibilitychange", () => {
    if (document.visibilityState === "hidden") {
        persistSessionSnapshot();
    }
});

window.addEventListener("pagehide", persistSessionSnapshot);
window.addEventListener("beforeunload", persistSessionSnapshot);

(async () => {
    try {
        initTheme();
        initFontScale();
        await loadData();
        const restoredData = restoreState();
        sanitizeRestoredState();
        syncMeta();
        await maybeShowResumeNotice(restoredData);
        sessionStorage.setItem(getTabSessionKey(), "active");
        await ensureStudentName();
